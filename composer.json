{
    "name": "myerscode/package-discovery",
    "description": "A package to help find plugins for your product through Composer meta data!",
    "keywords": ["composer", "discovery", "meta", "plugins"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fred Myerscough",
            "email": "oniice@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "myerscode/utilities-bags": "^2026",
        "myerscode/utilities-files": "^2026"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Myerscode\\PackageDiscovery\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse",
        "tests": "vendor/bin/phpunit --testdox --no-coverage --colors=always",
        "test-coverage": "vendor/bin/phpunit --testdox --colors=always",
        "security-audit": "@composer audit"
    }
}
